DATABASE_USER="user"
DATABASE_PASSWORD="password"
DATABASE_NAME="db_name"
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/db_name

# JWT
ACCESS_SECRET_KEY="secret"
ACCESS_MINUTES_EXPIRE=30
REFRESH_SECRET_KEY="secret"
REFRESH_DAYS_EXPIRE=7
ALGORITHM=HS256

# Admin
ADMIN_FIRST_NAME=ADMIN
ADMIN_LAST_NAME=ADMIN
ADMIN_USERNAME=ADMINADMIN
ADMIN_EMAIL=ADMIN@example.com
ADMIN_PASSWORD=ADMINADMIN

# Other
SOFT_DELETE_RETENTION_DAYS=30

# Email
GMAIL_USERNAME="your@email.com"
GMAIL_PASSWORD="app password" # You will need to create an app password in your email
RECOVERY_MINUTES=30
RECOVERY_SECRET_KEY="secret"